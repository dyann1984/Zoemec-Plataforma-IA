# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PRICE_MODEL=gpt-4.1-mini
OPENAI_VISUAL_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
ZOEMEC_AI_PORT=8787

# Firebase Web SDK (public browser configuration, not admin credentials)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin para funciones serverless de Vercel.
# Opcion A: pega el JSON completo del service account.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Opcion B: usa campos separados si no quieres pegar JSON completo.
FIREBASE_PROJECT_ID=zoemec-plataforma-ia
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Lista de correos (separados por coma) que siempre se tratan como administrador,
# ademas de Firestore users/{uid}.role y del custom claim admin=true. Se lee igual
# en el cliente (VITE_ADMIN_EMAILS) y en las funciones serverless (mismo nombre).
VITE_ADMIN_EMAILS=

# Bucket de Firebase Storage para el admin SDK (opcional). Si se omite, se usa
# "<project_id>.appspot.com" del service account. Aqui vive el import de OneDrive.
FIREBASE_STORAGE_BUCKET=

# OneDrive / Microsoft Graph (Biblioteca: conectar, listar e importar archivos).
# App registrada en Azure AD. Sin estas variables, la conexion no se activa y
# se muestra un aviso honesto en Biblioteca y en Panel Admin -> OneDrive.
VITE_ONEDRIVE_CLIENT_ID=
VITE_ONEDRIVE_TENANT_ID=common
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=common

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_URL=

# URL publica de la app desplegada, por ejemplo:
# PUBLIC_APP_URL=https://tu-proyecto.vercel.app
PUBLIC_APP_URL=

# OpenAI Build Week demo mode
VITE_DEMO_MODE=true
