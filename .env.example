# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PRICE_MODEL=gpt-4.1-mini
OPENAI_VISUAL_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
ZOEMEC_AI_PORT=8787

# Firebase Web SDK (public browser configuration, not admin credentials)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin para funciones serverless de Vercel.
# Opcion A: pega el JSON completo del service account.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Opcion B: usa campos separados si no quieres pegar JSON completo.
FIREBASE_PROJECT_ID=zoemec-plataforma-ia
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_URL=

# URL publica de la app desplegada, por ejemplo:
# PUBLIC_APP_URL=https://tu-proyecto.vercel.app
PUBLIC_APP_URL=

# OpenAI Build Week demo mode
VITE_CONTEST_MODE=true
